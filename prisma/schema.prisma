generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id         String   @id @default(dbgenerated("gen_random_uuid()"))
  user_id    String   @unique
  username   String?
  avatar_url String?
  is_admin   Boolean? @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("Profile")
}

model Collection {
  id         String   @id @default(dbgenerated("gen_random_uuid()"))
  name       String
  owner_id   String
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("Collection")
}

model CollectionItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()"))
  collection_id  String
  card_name      String
  card_set       String
  card_number    String?
  rarity         String?
  condition      String?
  purchase_price Decimal? @db.Decimal(10, 2)
  image_url      String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  // Price comparison fields
  market_avg_price  Decimal? @db.Decimal(10, 2)
  last_price_check  DateTime? @db.Timestamptz(6)
  price_source      String?

  @@map("CollectionItem")
}

model PricePoint {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  item_id     String
  value       Decimal  @db.Decimal(10, 2)
  provider    String   @default("mock")
  recorded_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("PricePoint")
}

model SharedCollectionMember {
  id            String   @id @default(dbgenerated("gen_random_uuid()"))
  collection_id String
  user_id       String
  role          String
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  @@unique([collection_id, user_id])
  @@map("SharedCollectionMember")
}

model Listing {
  id              String   @id @default(dbgenerated("gen_random_uuid()"))
  item_id         String   @unique
  seller_id       String
  asking_price    Decimal  @db.Decimal(10, 2)
  status          String   @default("active")
  market_avg_price Decimal? @db.Decimal(10, 2)
  price_source    String?
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  @@map("Listing")
}
